# ─── App ──────────────────────────────────────────────────────────
APP_NAME="AI Career Platform"
APP_ENV=development
SECRET_KEY=change-me-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL=

# ─── Groq ──────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=

# ─── Gemini ───────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=
# ─── OpenRouter ─────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# ─── Anthropic (optional — only if you get a paid key later) ─────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-haiku-20240307

# ─── Provider Routing ─────────────────────────────────────────────
# Which provider handles each feature — change here, zero code change
PROVIDER_SKILLS=groq
PROVIDER_CAREERS=groq
PROVIDER_RESUME=gemini
PROVIDER_CHAT=gemini
PROVIDER_JOBS=groq

# ─── File Storage (Cloudinary free tier: 10GB) ────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Vector Store ─────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data

# ─── CORS ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
