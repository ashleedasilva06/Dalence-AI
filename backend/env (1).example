# ─── App ──────────────────────────────────────────────────────────
APP_NAME="AI Career Platform"
APP_ENV=development
SECRET_KEY=change-me-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Database ─────────────────────────────────────────────────────
# Get free PostgreSQL from https://neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Groq (skills + careers + jobs) ──────────────────────────────
# Free: 14,400 req/day — get key at https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Gemini (chatbot + resume scoring) ───────────────────────────
# Free: 1,500 req/day — get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# ─── OpenRouter (automatic fallback) ─────────────────────────────
# Free models available — get key at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ─── Anthropic (optional — only if you get a paid key later) ─────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-haiku-20240307

# ─── Provider Routing ─────────────────────────────────────────────
# Which provider handles each feature — change here, zero code change
PROVIDER_SKILLS=groq
PROVIDER_CAREERS=groq
PROVIDER_RESUME=gemini
PROVIDER_CHAT=gemini
PROVIDER_JOBS=groq

# ─── File Storage (Cloudinary free tier: 10GB) ────────────────────
# Get from https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Vector Store ─────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data

# ─── CORS ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
