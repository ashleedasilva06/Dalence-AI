# ─── App ──────────────────────────────────────────────────────────
APP_NAME="AI Career Platform"
APP_ENV=development
SECRET_KEY=change-me-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── AI Provider ──────────────────────────────────────────────────
# Options: "openrouter" or "anthropic"
AI_PROVIDER=openrouter

# OpenRouter (free models available — get key at https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-...
# Free models you can use:
#   meta-llama/llama-3.3-8b-instruct:free   (fast, good quality)
#   mistralai/mistral-7b-instruct:free       (alternative)
#   google/gemma-3-12b-it:free               (Google's model)
OPENROUTER_MODEL=meta-llama/llama-3.3-8b-instruct:free

# Anthropic (if you have a paid key)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-haiku-20240307

# ─── File Storage (Cloudinary free tier) ──────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Vector Store ─────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data

# ─── CORS ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
